---
import { roles } from '../data/experience';
import { certifications } from '../data/site';
---

<section id="experience" class="section">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">Track record</span>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Experience</h2>
      <p class="text-fg-muted mt-4 text-lg">
        12+ years delivering platform and reliability work for banks, security vendors and
        high-growth SaaS — most recently leading teams and owning observability at scale.
      </p>
    </div>

    <ol class="border-line mt-12 space-y-3 border-l pl-6 md:pl-8">
      {
        roles.map((r) => (
          <li class="relative">
            <span
              class:list={[
                'ring-ink-950 absolute top-2 -left-[1.65rem] h-3 w-3 rounded-full ring-4 md:-left-[2.15rem]',
                r.current ? 'bg-accent' : 'bg-line',
              ]}
            />
            <div class="card p-5 md:p-6">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="text-lg font-semibold">
                  {r.title} · <span class="text-accent-soft">{r.company}</span>
                </h3>
                <span class="text-fg-subtle font-mono text-xs">{r.period}</span>
              </div>
              <p class="text-fg-subtle mt-0.5 text-sm">{r.location}</p>
              <ul class="mt-4 space-y-2">
                {r.highlights.map((h) => (
                  <li class="text-fg-muted flex gap-2.5 text-sm">
                    <svg
                      class="text-accent mt-1 shrink-0"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="m5 12 4 4L19 7"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>

    <!-- Certifications -->
    <div class="mt-12">
      <h3 class="eyebrow">Certifications</h3>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {
          certifications.map((c) => {
            const Tag = c.href ? 'a' : 'div';
            return (
              <li>
                <Tag
                  {...(c.href ? { href: c.href, target: '_blank', rel: 'noopener' } : {})}
                  class:list={['card flex items-center gap-3 p-4', c.href && 'card-hover']}
                >
                  <svg
                    class="text-accent shrink-0"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="9" r="6" stroke="currentColor" stroke-width="1.6" />
                    <path
                      d="m9 14-1.5 7L12 19l4.5 2L15 14"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span>
                    <span class="block text-sm font-medium">{c.name}</span>
                    <span class="text-fg-subtle block text-xs">{c.issuer}</span>
                  </span>
                </Tag>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>
