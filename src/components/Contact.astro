---
import { site } from '../data/site';

// Public, build-time keys (safe to expose). Set as PUBLIC_* env vars in CI.
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';
const formEnabled = web3formsKey.length > 0;

// Client-side AJAX submit (sent raw via set:html so it isn't bundled/processed).
const formScript = `
(function () {
  const form = document.getElementById('contact-form');
  if (!form) return;
  const feedback = form.querySelector('[data-feedback]');
  const button = form.querySelector('button[type=submit]');
  const label = button.querySelector('[data-label]');
  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    button.disabled = true;
    label.textContent = 'Sending…';
    feedback.classList.add('hidden');
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.message || 'Submission failed');
      form.reset();
      feedback.textContent = "Thanks — your message is on its way. I'll be in touch soon.";
      feedback.style.color = 'var(--color-accent-soft)';
      label.textContent = 'Message sent ✓';
    } catch (err) {
      feedback.textContent = 'Something went wrong. Please email consulting@anantajna.com directly.';
      feedback.style.color = '#f87171';
      label.textContent = 'Send message';
      button.disabled = false;
    }
    feedback.classList.remove('hidden');
  });
})();
`;
---

<section id="contact" class="section border-line bg-ink-900 border-t">
  <div class="container-page grid gap-12 lg:grid-cols-2">
    <div>
      <span class="eyebrow">Let’s talk</span>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Have a platform challenge?</h2>
      <p class="text-fg-muted mt-4 text-lg">
        Whether you’re standing up a cloud foundation, scaling Kubernetes, taming your cloud bill or
        hiring a freelance platform lead — I’d love to hear about it.
      </p>

      <div class="mt-8 space-y-3">
        <a href={`mailto:${site.email}`} class="card card-hover flex items-center gap-4 p-4">
          <span
            class="border-line bg-ink-800 text-accent flex h-11 w-11 items-center justify-center rounded-xl border"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
          </span>
          <span>
            <span class="text-fg-subtle block text-xs">Email</span>
            <span class="block font-medium">{site.email}</span>
          </span>
        </a>
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener"
          class="card card-hover flex items-center gap-4 p-4"
        >
          <span
            class="border-line bg-ink-800 text-accent flex h-11 w-11 items-center justify-center rounded-xl border"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0ZM.24 8.25h4.46V24H.24V8.25Zm7.5 0h4.28v2.15h.06c.6-1.13 2.06-2.32 4.24-2.32 4.54 0 5.38 2.99 5.38 6.87V24h-4.46v-6.98c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.68 1.81-2.68 3.68V24H7.74V8.25Z"
              ></path>
            </svg>
          </span>
          <span>
            <span class="text-fg-subtle block text-xs">LinkedIn</span>
            <span class="block font-medium">in/santoshghegde</span>
          </span>
        </a>
        <p class="text-fg-subtle flex items-center gap-2 pt-2 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M12 21s-7-5.7-7-11a7 7 0 0 1 14 0c0 5.3-7 11-7 11Z"
              stroke="currentColor"
              stroke-width="1.6"></path>
            <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"></circle>
          </svg>
          {site.location}
        </p>
      </div>
    </div>

    {
      formEnabled ? (
        <form id="contact-form" class="card flex flex-col gap-4 p-6 md:p-8">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New enquiry via anantajna.com" />
          <input type="hidden" name="from_name" value="anantajna.com" />
          {/* Honeypot — bots fill this, humans never see it */}
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm">
              <span class="text-fg-muted mb-1.5 block">Name</span>
              <input
                name="name"
                required
                autocomplete="name"
                class="form-field"
                placeholder="Jane Doe"
              />
            </label>
            <label class="block text-sm">
              <span class="text-fg-muted mb-1.5 block">Email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="form-field"
                placeholder="jane@company.com"
              />
            </label>
          </div>
          <label class="block text-sm">
            <span class="text-fg-muted mb-1.5 block">
              Company <span class="text-fg-subtle">(optional)</span>
            </span>
            <input
              name="company"
              autocomplete="organization"
              class="form-field"
              placeholder="Company / project"
            />
          </label>
          <label class="block text-sm">
            <span class="text-fg-muted mb-1.5 block">How can I help?</span>
            <textarea
              name="message"
              required
              rows="5"
              class="form-field resize-y"
              placeholder="A few lines about your team, stack and what you need…"
            />
          </label>

          {turnstileKey && (
            <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="dark" />
          )}

          <button type="submit" class="btn btn-primary mt-1 w-full">
            <span data-label>Send message</span>
          </button>
          <p data-feedback role="status" aria-live="polite" class="hidden text-center text-sm" />
          <p class="text-fg-subtle text-center text-xs">
            I typically reply within one business day.
          </p>
        </form>
      ) : (
        <div class="card flex flex-col items-start justify-center gap-4 p-8">
          <p class="text-fg-muted">
            The contact form isn’t configured yet. In the meantime, the fastest way to reach me is
            by email — I read every message.
          </p>
          <a href={`mailto:${site.email}`} class="btn btn-primary">
            Email {site.email}
          </a>
        </div>
      )
    }
  </div>
</section>

{
  turnstileKey && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline />
  )
}

{formEnabled && <script is:inline set:html={formScript} />}
