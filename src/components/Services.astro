---
import { services, type Service } from '../data/services';

// Inline icon paths keyed by Service.icon — avoids an icon-library dependency.
const icons: Record<Service['icon'], string> = {
  cloud: 'M7 18a4 4 0 0 1 0-8 5 5 0 0 1 9.6-1.5A4 4 0 0 1 17 18H7Z',
  layers: 'M12 3 3 8l9 5 9-5-9-5Zm-9 9 9 5 9-5M3 16l9 5 9-5',
  pipeline:
    'M4 7h6m4 0h6M4 17h6m4 0h6M10 7a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm8 0a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM10 17a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm8 0a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z',
  pulse: 'M3 12h4l2 6 4-14 2 8h6',
  shield: 'M12 3l8 3v5c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3Zm-2 8 1.8 1.8L15 9',
  coins:
    'M8 8a5 2.5 0 1 0 0-5 5 2.5 0 0 0 0 5Zm0 0v8c0 1.4 2.2 2.5 5 2.5M3 8v8c0 1.4 2.2 2.5 5 2.5m8-9.5a5 2.5 0 1 0 0-5 5 2.5 0 0 0 0 5Zm0 0v8c0 1.4-2.2 2.5-5 2.5',
};
---

<section id="services" class="section">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">What I do</span>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Consulting services</h2>
      <p class="text-fg-muted mt-4 text-lg">
        End-to-end platform capability — from cloud foundations to the developer experience on top.
        Engage me for a focused project or as an embedded platform lead.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article class="card card-hover flex flex-col gap-4 p-6">
            <span class="border-line bg-ink-800 text-accent flex h-12 w-12 items-center justify-center rounded-xl border">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={icons[s.icon]} />
              </svg>
            </span>
            <h3 class="text-xl font-semibold">{s.title}</h3>
            <p class="text-fg-muted">{s.summary}</p>
            <ul class="mt-auto space-y-2 pt-2">
              {s.points.map((p) => (
                <li class="text-fg-muted flex gap-2.5 text-sm">
                  <svg
                    class="text-accent mt-0.5 shrink-0"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="m5 12 4 4L19 7"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
