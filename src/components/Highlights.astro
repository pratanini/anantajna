---
import { stats } from '../data/site';
---

<section aria-label="Key results" class="container-page -mt-4 md:-mt-8">
  <dl
    class="card divide-line grid grid-cols-2 divide-x divide-y overflow-hidden md:grid-cols-4 md:divide-y-0"
  >
    {
      stats.map((s) => (
        <div class="px-5 py-6 text-center md:px-6 md:py-8">
          <dt class="sr-only">{s.label}</dt>
          <dd>
            <span class="font-display gradient-text block text-3xl font-bold md:text-4xl">
              {s.value}
            </span>
            <span class="text-fg-muted mt-2 block text-sm">{s.label}</span>
          </dd>
        </div>
      ))
    }
  </dl>
</section>
