---
import { site } from '../data/site';

const links = [
  { href: '#services', label: 'Services' },
  { href: '#expertise', label: 'Expertise' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="border-line bg-ink-950/80 sticky top-0 z-40 border-b backdrop-blur-md">
  <nav class="container-page flex h-16 items-center justify-between gap-4">
    <a href="#top" class="font-display flex items-baseline gap-2 text-lg font-bold">
      <span class="gradient-text">{site.name}</span>
      <span class="text-fg-subtle hidden text-xs font-medium sm:inline">/ {site.role}</span>
    </a>

    <div class="flex items-center gap-1 md:gap-2">
      <ul class="hidden items-center gap-1 md:flex">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-fg-muted hover:text-fg rounded-lg px-3 py-2 text-sm transition-colors"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="#contact" class="btn btn-primary !px-4 !py-2 text-sm">Get in touch</a>
    </div>
  </nav>
</header>
